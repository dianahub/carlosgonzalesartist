generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Painting {
  id           String   @id @default(cuid())
  title        String
  width        Float
  height       Float
  unit         String   @default("in")
  medium       String
  price        Float?
  status       String   @default("available")
  imageUrl     String
  cloudinaryId String
  order        Int      @default(0)
  visible      Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model SiteContent {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

model Exhibit {
  id          String         @id @default(cuid())
  title       String
  venue       String
  location    String
  startDate   DateTime
  endDate     DateTime?
  description String?
  imageUrl    String?
  link        String?
  visible     Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  photos      ExhibitPhoto[]
}

model ExhibitPhoto {
  id           String   @id @default(cuid())
  exhibitId    String
  exhibit      Exhibit  @relation(fields: [exhibitId], references: [id], onDelete: Cascade)
  imageUrl     String
  cloudinaryId String
  caption      String?
  order        Int      @default(0)
  createdAt    DateTime @default(now())
}
